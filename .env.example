PORT=9111
WSPORT=9111
HOST=0.0.0.0
UID=1000
GID=1000

# generate_polyphonic の実行場所
# true  : GitHub Actions (workflow_dispatch) に投げて、Artifacts(result.json/result.wav) を手動アップロードして確認
# false : ホスティングサーバ上で直接 generate_polyphonic を実行（結果は画面に直接反映）
RUN_GENERATE_POLYPHONIC_ON_GITHUB_ACTIONS=true
# GitHub repository
GITHUB_OWNER=あなたのowner
GITHUB_REPO=あなたのrepo
GITHUB_REF=main

# この実装が叩くworkflowファイル名
GITHUB_WORKFLOW=polyphonic_generate.yml

# workflow_dispatch を叩けるトークン
GITHUB_TOKEN=ghp_xxx...（または fine-grained PAT）

# influxdb
# Local Docker uses InfluxDB 1.8 with db=timeseries.
# Production uses InfluxDB Cloud bucket=timeseries plus a one-time DBRP mapping:
# db=timeseries, rp=autogen -> bucket=timeseries.
INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_TOKEN=xxx...
INFLUX_BUCKET=timeseries
INFLUX_DB=timeseries
INFLUX_ORG_ID=xxx...
INFLUX_BUCKET_ID=xxx...
INFLUX_MEASUREMENT=timeseries
INFLUX_FIELD=value
INFLUX_RP=autogen
INFLUX_V1_AUTH_SCHEME=query
INFLUX_AUTO_CREATE_DBRP=false

# Set true only once with a DBRP-management token, then remove it.
ENSURE_INFLUX_DBRP_ON_START=false

# Set true only once when seeding hosted InfluxDB, then remove it.
SEED_ON_START=false
